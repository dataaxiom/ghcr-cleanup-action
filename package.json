{
  "name": "ghcr-cleanup-action",
  "description": "GitHub Container Registry Cleanup Action",
  "version": "main",
  "author": "Dataaxiom Inc",
  "homepage": "https://github.com/dataaxiom/ghcr-cleanup-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dataaxiom/ghcr-cleanup-action.git"
  },
  "bugs": {
    "url": "https://github.com/dataaxiom/ghcr-cleanup-action/issues"
  },
  "keywords": [
    "ci",
    "ghcr.io"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "scripts": {
    "bundle": "npm run format:write && npm run package && npm run ci-tester",
    "ci-test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage && npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "ci-tester": "npx ncc build src/ci-tester.ts -o citester --source-map",
    "package:watch": "npm run package -- --watch",
    "test": "vitest run",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "BSD-3-Clause",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@octokit/auth-token": "^6.0.0",
    "@octokit/plugin-request-log": "^6.0.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "axios": "^1.16.0",
    "axios-retry": "^4.5.0",
    "human-interval": "^2.0.1",
    "stdio": "^2.1.3",
    "wildcard-match": "^5.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.4.1",
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "axios-logger": "^2.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.3",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
